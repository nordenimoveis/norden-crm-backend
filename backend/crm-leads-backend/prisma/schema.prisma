generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  gestor
  corretor
  admin
}

enum LeadStatus {
  novo
  respondeu
  em_atendimento
  visita_agendada
  proposta
  negocio_fechado
  perdido
  frio_standby
}

enum LeadOrigem {
  meta_ads
  site_imobzi
  legado_imobzi
  importacao_planilha
  manual
}

enum LeadTemperatura {
  nao_avaliado
  frio
  morno
  quente
}

enum ExecucaoStatus {
  ativa
  pausada
  concluida
  cancelada
}

enum MensagemDirecao {
  enviada
  recebida
}

enum MensagemStatus {
  pendente
  enviada
  entregue
  lida
  falhou
}

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senhaHash    String   @map("senha_hash")
  papel        UserRole @default(corretor)
  ativo        Boolean  @default(true)
  ordemRoleta  Int      @default(0) @map("ordem_roleta")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  leads             Lead[]       @relation("CorretorLeads")
  mensagensEnviadas Mensagem[]   @relation("MensagemEnviadaPor")
  quickReplies      QuickReply[] @relation("QuickReplyDoUsuario")
  campanhasDisparoCriadas CampanhaDisparo[] @relation("CampanhaDisparoCriadaPor")

  @@map("usuarios")
}

model Imovel {
  id                 String   @id @default(uuid())
  titulo             String
  bairro             String?
  cidade             String   @default("Florianópolis")
  valor              Decimal? @db.Decimal(14, 2)
  referenciaExterna  String?  @map("referencia_externa")
  ativo              Boolean  @default(true)
  criadoEm           DateTime @default(now()) @map("criado_em")

  leads Lead[]

  @@map("imoveis")
}

model Campanha {
  id             String   @id @default(uuid())
  nome           String
  metaCampaignId String?  @map("meta_campaign_id")
  metaFormId     String?  @map("meta_form_id")
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")

  leads Lead[]

  @@map("campanhas")
}

enum CampanhaDisparoStatus {
  rascunho
  pronta
  enviando
  concluida
  cancelada
}

model CampanhaDisparo {
  id                 String   @id @default(uuid())
  nome               String
  templateMensagemId String   @map("template_mensagem_id")
  templateMensagem   TemplateMensagem @relation(fields: [templateMensagemId], references: [id])
  status             CampanhaDisparoStatus @default(rascunho)

  criadoPorUsuarioId String   @map("criado_por_usuario_id")
  criadoPor          Usuario  @relation("CampanhaDisparoCriadaPor", fields: [criadoPorUsuarioId], references: [id])

  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  destinatarios CampanhaDisparoLead[]

  @@map("campanhas_disparo")
}

model CampanhaDisparoLead {
  id                String   @id @default(uuid())
  campanhaDisparoId String   @map("campanha_disparo_id")
  campanhaDisparo   CampanhaDisparo @relation(fields: [campanhaDisparoId], references: [id], onDelete: Cascade)
  leadId            String   @map("lead_id")
  lead              Lead     @relation(fields: [leadId], references: [id])

  status    String    @default("pendente")
  erro      String?
  enviadoEm DateTime? @map("enviado_em")

  @@unique([campanhaDisparoId, leadId])
  @@map("campanha_disparo_leads")
}

model Lead {
  id           String     @id @default(uuid())
  nome         String?
  telefone     String
  email        String?

  campanhaId   String?    @map("campanha_id")
  campanha     Campanha?  @relation(fields: [campanhaId], references: [id])

  imovelId     String?    @map("imovel_id")
  imovel       Imovel?    @relation(fields: [imovelId], references: [id])

  corretorId   String?    @map("corretor_id")
  corretor     Usuario?   @relation("CorretorLeads", fields: [corretorId], references: [id])

  status       LeadStatus @default(novo)
  origem       LeadOrigem @default(meta_ads)
  temperatura  LeadTemperatura @default(nao_avaliado)
  imobziId     String?    @unique @map("imobzi_id") // evita duplicidade ao receber o mesmo lead do Imobzi mais de uma vez
  atendimentoHumano Boolean @default(false) @map("atendimento_humano")
  payloadBruto Json?      @map("payload_bruto")
  dataVisita   DateTime?  @map("data_visita")

  criadoEm     DateTime   @default(now()) @map("criado_em")
  atualizadoEm DateTime   @updatedAt @map("atualizado_em")

  execucoesCadencia LeadCadenciaExecucao[]
  mensagens         Mensagem[]
  destinatarioDeCampanhas CampanhaDisparoLead[]

  @@unique([telefone, campanhaId])
  @@index([status])
  @@index([corretorId])
  @@index([temperatura])
  @@map("leads")
}

model Cadencia {
  id        String   @id @default(uuid())
  nome      String
  ativo     Boolean  @default(true)
  padrao    Boolean  @default(false)
  criadoEm  DateTime @default(now()) @map("criado_em")

  passos    CadenciaPasso[]
  execucoes LeadCadenciaExecucao[]

  @@map("cadencias")
}

model CadenciaPasso {
  id                 String   @id @default(uuid())
  cadenciaId         String   @map("cadencia_id")
  cadencia           Cadencia @relation(fields: [cadenciaId], references: [id], onDelete: Cascade)
  ordem              Int
  atrasoMinutos      Int      @map("atraso_minutos")
  templateMensagemId String?  @map("template_mensagem_id")
  template           TemplateMensagem? @relation(fields: [templateMensagemId], references: [id])
  condicao           String   @default("sem_resposta")

  @@unique([cadenciaId, ordem])
  @@map("cadencia_passos")
}

model LeadCadenciaExecucao {
  id                String         @id @default(uuid())
  leadId            String         @map("lead_id")
  lead              Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  cadenciaId        String         @map("cadencia_id")
  cadencia          Cadencia       @relation(fields: [cadenciaId], references: [id])
  passoAtual        Int            @default(0) @map("passo_atual")
  status            ExecucaoStatus @default(ativa)
  proximoDisparoEm  DateTime?      @map("proximo_disparo_em")
  proximoJobId      String?        @map("proximo_job_id")
  iniciadaEm        DateTime       @default(now()) @map("iniciada_em")
  atualizadaEm      DateTime       @updatedAt @map("atualizada_em")

  @@index([proximoDisparoEm])
  @@map("lead_cadencia_execucao")
}

model TemplateMensagem {
  id               String   @id @default(uuid())
  nome             String
  conteudo         String
  metaTemplateName String?  @map("meta_template_name")
  aprovadoMeta     Boolean  @default(false) @map("aprovado_meta")
  criadoEm         DateTime @default(now()) @map("criado_em")

  passos    CadenciaPasso[]
  mensagens Mensagem[]
  campanhasDisparo CampanhaDisparo[]

  @@map("templates_mensagem")
}

enum QuickReplyTipo {
  global
  pessoal
}

model QuickReply {
  id             String         @id @default(uuid())
  titulo         String
  textoMensagem  String         @map("texto_mensagem")
  tipo           QuickReplyTipo

  usuarioId      String?        @map("usuario_id")
  usuario        Usuario?       @relation("QuickReplyDoUsuario", fields: [usuarioId], references: [id])

  ativo          Boolean        @default(true)
  criadoEm       DateTime       @default(now()) @map("criado_em")
  atualizadoEm   DateTime       @updatedAt @map("atualizado_em")

  @@index([tipo])
  @@index([usuarioId])
  @@map("quick_replies")
}

model Mensagem {
  id                 String          @id @default(uuid())
  leadId             String          @map("lead_id")
  lead               Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direcao            MensagemDirecao
  conteudo           String
  templateId         String?         @map("template_id")
  template           TemplateMensagem? @relation(fields: [templateId], references: [id])
  status             MensagemStatus  @default(pendente)
  whatsappMessageId  String?         @map("whatsapp_message_id")

  enviadaPorUsuarioId String?  @map("enviada_por_usuario_id")
  enviadaPorUsuario   Usuario? @relation("MensagemEnviadaPor", fields: [enviadaPorUsuarioId], references: [id])

  enviadaEm          DateTime?       @map("enviada_em")
  criadoEm           DateTime        @default(now()) @map("criado_em")

  @@index([leadId, criadoEm])
  @@map("mensagens")
}
