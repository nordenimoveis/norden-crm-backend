{
  "name": "crm-leads-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend do CRM de leads WhatsApp (Meta Ads + Cadência)",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/cadencia.worker.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/cadencia.worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "sync:imobzi": "tsx scripts/sync-imobzi-legado.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/sensible": "^5.6.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "pusher": "^5.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.5.0",
    "eslint": "^9.9.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
